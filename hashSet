
import java.util.*;

class Hashset 
{
    public static void main(String[] args)
    {  
        String s="mississippi";
        HashSet<Character> hs = new HashSet<>();
       for(Character c:s.toCharArray()){
           hs.add(c);
       }
         System.out.println("HashSet :"+hs);
          System.out.println(hs.size());
       
    }

 }
