class Main {
    public static void main(String[] args) {
        int m=20;
        int n=3;
        System.out.println("before swap n=:"+n);
        System.out.println("before swap m=:"+m);
       
        m+=n;
        n=m-n;
        m-=n;
        System.out.println("after swap n=:"+n);
        System.out.println("after swap m=:"+m);
    
    }
}
